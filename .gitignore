# =============================
# JAR 처리 (수동 JAR 방식)
# =============================

# 기본적으로 jar는 무시
*.jar

# 하지만 WEB-INF/lib 안의 jar는 반드시 포함
!src/main/webapp/WEB-INF/lib/*.jar

