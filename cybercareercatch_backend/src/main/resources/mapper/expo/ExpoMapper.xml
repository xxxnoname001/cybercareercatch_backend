<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="expo">

	<!-- 관리자 박람회 일정 목록 조회 -->
	<select id="selectExpoList" parameterType="map" resultType="com.ccc.expo.dto.ExpoListDTO">
		<![CDATA[
		SELECT * FROM (
			SELECT ROWNUM AS RNUM, A.*
			FROM (
				SELECT
					EXPO_NUMBER,
					EXPO_NAME,
					START_DATE,
					END_DATE,
					LOCATION,
					REG_DATE
				FROM TBL_EXPO
				ORDER BY EXPO_NUMBER DESC
			) A
		)
		WHERE RNUM BETWEEN #{startRow} AND #{endRow}
		]]>
	</select>

	<!-- 관리자 박람회 총 개수 -->
	<select id="getExpoTotal" resultType="int">
		SELECT COUNT(EXPO_NUMBER)
		FROM TBL_EXPO
	</select>

	<!--
	<!-- 관리자 박람회 일정 상세 조회 
	<select id="selectExpoDetail" parameterType="int" resultType="com.ccc.expo.dto.ExpoDetailDTO">
		SELECT
			E.EXPO_NUMBER,
			E.EXPO_NAME,
			E.START_DATE,
			E.END_DATE,
			E.LOCATION,
			E.REG_DATE,
			C.COMPANY_NUMBER,
			C.COMPANY_NAME
		FROM TBL_EXPO E
		LEFT JOIN TBL_EXPO_COMPANY EC
		ON E.EXPO_NUMBER = EC.EXPO_NUMBER
		LEFT JOIN TBL_COMPANY C
		ON EC.COMPANY_NUMBER = C.COMPANY_NUMBER
		WHERE E.EXPO_NUMBER = #{expoNumber}
		ORDER BY C.COMPANY_NUMBER
	</select>
	-->

	<!-- 관리자 박람회 일정 삭제 -->
	<delete id="deleteExpo" parameterType="int">
		DELETE FROM TBL_EXPO
		WHERE EXPO_NUMBER = #{expoNumber}
	</delete>





<!-- 달력에 뿌릴 박람회 일정 목록 -->
    <select id="selectExpoCalendarList" resultType="com.ccc.expo.dto.ExpoCalendarDTO">
        SELECT
            EXPO_NUMBER,
            EXPO_NAME,
            START_DATE,
            END_DATE
        FROM TBL_EXPO
        ORDER BY START_DATE
    </select>

    <!-- 클릭 시 박람회 상세 + 참여 기업 목록 -->
    <select id="selectExpoDetailList" parameterType="int" resultType="com.ccc.expo.dto.ExpoDetailDTO">
        SELECT
            E.EXPO_NUMBER,
            E.EXPO_NAME,
            E.LOCATION,
            C.COMPANY_NUMBER,
            C.COMPANY_NAME,
            C.COMPANY_ADDRESS
        FROM TBL_EXPO E
        LEFT JOIN TBL_EXPO_COMPANY EC
            ON E.EXPO_NUMBER = EC.EXPO_NUMBER
        LEFT JOIN TBL_COMPANY C
            ON EC.COMPANY_NUMBER = C.COMPANY_NUMBER
        WHERE E.EXPO_NUMBER = #{expoNumber}
        ORDER BY C.COMPANY_NAME
    </select>
</mapper>
